# Copy this file to .env and adjust values for your environment.
# .env is gitignored and never committed.

# Registry + owner prefix for image names.
# Leave unset to use local image names (e.g. "saunafs-master").
# Set to your ghcr.io path to build/push to the registry.
LEILFS_REGISTRY=ghcr.io/henres/leilfs-container  # mirrors ghcr.io/$GITHUB_REPOSITORY in CI

# Image tag to use (default: latest).
LEILFS_IMAGE_TAG=5.7.1

# LeilFS apt package version to install.
# Leave unset to install the latest version available in the repository.
SAUNAFS_VERSION=5.7.1-2
